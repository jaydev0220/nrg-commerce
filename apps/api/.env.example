NODE_ENV=development
PORT=3000
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:4173,http://localhost:5173
BODY_LIMIT=64kb
LOG_LEVEL=debug
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nrg_commerce

ACCESS_TOKEN_SECRET=development-access-secret
REFRESH_TOKEN_SECRET=development-refresh-secret
PENDING_TOKEN_SECRET=development-pending-secret
DATA_ENCRYPTION_SECRET=development-data-secret

ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
PENDING_TOKEN_TTL_SECONDS=300
SESSION_TTL_SECONDS=604800
SESSION_ABSOLUTE_TTL_SECONDS=2592000

TOTP_ISSUER=NRG Commerce
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=NRG Commerce
WEBAUTHN_ORIGIN=http://localhost:5173

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

R2_ACCOUNT_ID=development-account-id
R2_BUCKET_NAME=development-bucket
R2_ACCESS_KEY_ID=development-access-key-id
R2_SECRET_ACCESS_KEY=development-secret-access-key
R2_PUBLIC_BASE_URL=https://example.com/assets
R2_ASSET_KEY_PREFIX=products/skus
R2_UPLOAD_URL_TTL_SECONDS=900
