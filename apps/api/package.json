{
	"name": "@apps/api",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"files": [
		"build"
	],
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node24 --packages=external --sourcemap --alias:@packages/database=../../packages/database/src/index.ts --alias:@packages/schemas=../../packages/schemas/src/index.ts --outfile=build/index.js",
		"start": "node --enable-source-maps build/index.js",
		"check": "tsc --noEmit --project tsconfig.json",
		"format": "prettier --ignore-path ../../.prettierignore --write .",
		"lint": "prettier --ignore-path ../../.prettierignore --check . && eslint .",
		"test": "node --import tsx --test \"tests/**/*.test.ts\"",
		"test:coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-include=src/**/*.ts --test-coverage-lines=69 --test-coverage-branches=81 --test-coverage-functions=53 \"tests/**/*.test.ts\""
	},
	"dependencies": {
		"@aws-sdk/client-s3": "catalog:express",
		"@aws-sdk/s3-request-presigner": "catalog:express",
		"@prisma/adapter-pg": "catalog:db",
		"@prisma/client": "catalog:db",
		"@simplewebauthn/server": "catalog:express",
		"argon2": "catalog:express",
		"cookie": "catalog:express",
		"cors": "catalog:express",
		"express": "catalog:express",
		"express-rate-limit": "catalog:express",
		"helmet": "catalog:express",
		"jose": "catalog:express",
		"otplib": "catalog:express",
		"pg": "catalog:db",
		"pino": "catalog:express",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@eslint/js": "catalog:lint",
		"@packages/database": "workspace:*",
		"@packages/eslint-config": "workspace:*",
		"@packages/prettier-config": "workspace:*",
		"@packages/schemas": "workspace:*",
		"@packages/tsconfig": "workspace:*",
		"@types/cors": "catalog:express",
		"@types/express": "catalog:express",
		"@types/node": "catalog:",
		"eslint": "catalog:lint",
		"eslint-config-prettier": "catalog:lint",
		"esbuild": "catalog:",
		"globals": "catalog:lint",
		"prettier": "catalog:lint",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"typescript-eslint": "catalog:lint"
	}
}
