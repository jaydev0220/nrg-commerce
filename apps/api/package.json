{
	"name": "@apps/api",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "",
		"check": "if find . -path ./node_modules -prune -o \\( -name '*.ts' -o -name '*.mts' -o -name '*.cts' -o -name '*.tsx' \\) -print -quit | grep -q .; then tsc --noEmit --project ./tsconfig.json; else echo 'No TypeScript source files to check'; fi",
		"format": "prettier --ignore-path ../../.prettierignore --write .",
		"lint": "prettier --ignore-path ../../.prettierignore --check . && eslint ."
	},
	"dependencies": {
		"cors": "catalog:express",
		"express": "catalog:express",
		"helmet": "catalog:express",
		"multer": "catalog:express"
	},
	"devDependencies": {
		"@eslint/js": "catalog:lint",
		"@packages/eslint-config": "workspace:*",
		"@packages/prettier-config": "workspace:*",
		"@packages/tsconfig": "workspace:*",
		"@types/cors": "catalog:express",
		"@types/express": "catalog:express",
		"@types/node": "catalog:",
		"eslint": "catalog:lint",
		"eslint-config-prettier": "catalog:lint",
		"globals": "catalog:lint",
		"prettier": "catalog:lint",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"typescript-eslint": "catalog:lint"
	}
}
