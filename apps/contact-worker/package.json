{
	"name": "@apps/contact-worker",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"build": "wrangler types && wrangler deploy --dry-run --outdir build",
		"deploy": "wrangler deploy",
		"check": "wrangler types && tsc --noEmit --project tsconfig.json",
		"format": "prettier --ignore-path ../../.prettierignore --write .",
		"lint": "prettier --ignore-path ../../.prettierignore --check . && eslint .",
		"test": "wrangler types && node --import tsx --test \"tests/**/*.test.ts\"",
		"types": "wrangler types"
	},
	"dependencies": {
		"zod": "catalog:"
	},
	"devDependencies": {
		"@eslint/js": "catalog:lint",
		"@packages/eslint-config": "workspace:*",
		"@packages/prettier-config": "workspace:*",
		"@packages/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"eslint": "catalog:lint",
		"eslint-config-prettier": "catalog:lint",
		"prettier": "catalog:lint",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"typescript-eslint": "catalog:lint",
		"wrangler": "catalog:svelte"
	}
}
