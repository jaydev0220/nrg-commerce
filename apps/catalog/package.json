{
	"name": "@apps/catalog",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && wrangler types",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --ignore-path ../../.prettierignore --write .",
		"lint": "prettier --ignore-path ../../.prettierignore --check . && eslint .",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"types": "vite build && wrangler types"
	},
	"devDependencies": {
		"@eslint/js": "catalog:lint",
		"@inlang/paraglide-js": "catalog:svelte",
		"@lucide/svelte": "catalog:svelte",
		"@packages/components": "workspace:*",
		"@packages/eslint-config": "workspace:*",
		"@packages/prettier-config": "workspace:*",
		"@packages/schemas": "workspace:*",
		"@packages/seo": "workspace:*",
		"@packages/styles": "workspace:*",
		"@packages/tsconfig": "workspace:*",
		"@playwright/test": "catalog:test",
		"@sveltejs/adapter-cloudflare": "catalog:svelte",
		"@sveltejs/kit": "catalog:svelte",
		"@sveltejs/vite-plugin-svelte": "catalog:svelte",
		"@tailwindcss/vite": "catalog:svelte",
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:test",
		"@vitest/browser-playwright": "catalog:test",
		"eslint": "catalog:lint",
		"eslint-config-prettier": "catalog:lint",
		"eslint-plugin-svelte": "catalog:lint",
		"globals": "catalog:lint",
		"playwright": "catalog:test",
		"prettier": "catalog:lint",
		"prettier-plugin-svelte": "catalog:lint",
		"prettier-plugin-tailwindcss": "catalog:lint",
		"svead": "catalog:svelte",
		"svelte": "catalog:svelte",
		"svelte-check": "catalog:svelte",
		"tailwindcss": "catalog:svelte",
		"typescript": "catalog:",
		"typescript-eslint": "catalog:lint",
		"vite": "catalog:svelte",
		"vitest": "catalog:test",
		"vitest-browser-svelte": "catalog:test",
		"wrangler": "catalog:svelte"
	}
}
