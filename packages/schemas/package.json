{
	"name": "@packages/schemas",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"check": "tsc --noEmit --project tsconfig.json",
		"format": "prettier --ignore-path ../../.prettierignore --write .",
		"lint": "prettier --ignore-path ../../.prettierignore --check . && eslint .",
		"test": "node --import tsx --test \"tests/**/*.test.ts\"",
		"test:coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-include=src/**/*.ts --test-coverage-lines=99 --test-coverage-branches=93 --test-coverage-functions=94 \"tests/**/*.test.ts\""
	},
	"dependencies": {
		"zod": "catalog:"
	},
	"devDependencies": {
		"@eslint/js": "catalog:lint",
		"@packages/eslint-config": "workspace:*",
		"@packages/prettier-config": "workspace:*",
		"@packages/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"eslint": "catalog:lint",
		"eslint-config-prettier": "catalog:lint",
		"globals": "catalog:lint",
		"prettier": "catalog:lint",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"typescript-eslint": "catalog:lint"
	}
}
