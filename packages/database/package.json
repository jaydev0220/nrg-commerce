{
	"name": "@packages/database",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"check": "prisma validate && tsc --noEmit --project tsconfig.json",
		"format": "prettier --ignore-path ../../.prettierignore --write . && prisma format",
		"lint": "prettier --ignore-path ../../.prettierignore --check . && eslint .",
		"test": "prisma generate && tsc --project tsconfig.json && node --test build/tests/**/*.test.js",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:deploy": "prisma migrate deploy",
		"db:seed": "tsx prisma/seed.ts",
		"db:studio": "prisma studio"
	},
	"dependencies": {
		"@prisma/adapter-pg": "catalog:db",
		"@prisma/client": "catalog:db",
		"pg": "catalog:db"
	},
	"devDependencies": {
		"@eslint/js": "catalog:lint",
		"@packages/eslint-config": "workspace:*",
		"@packages/prettier-config": "workspace:*",
		"@packages/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"@types/pg": "catalog:db",
		"eslint": "catalog:lint",
		"eslint-config-prettier": "catalog:lint",
		"globals": "catalog:lint",
		"prettier": "catalog:lint",
		"prisma": "catalog:db",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"typescript-eslint": "catalog:lint"
	}
}
