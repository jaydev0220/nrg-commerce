NODE_ENV=development
PORT=3000
TRUST_PROXY_HOPS=1
CORS_ORIGINS=http://localhost:4173,http://localhost:5173
# Production must include the exact HTTPS admin origin in CORS_ORIGINS.
BODY_LIMIT=64kb
LOG_LEVEL=debug
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
# Production cookies must be secure. Use SameSite=none when the admin and API origins are cross-site.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nrg_commerce
# Production database URLs must include sslmode=verify-full.
# When the provider uses a private CA, mount its root certificate read-only and add
# sslrootcert=%2Frun%2Fsecrets%2Fdatabase-ca.crt to the production URL.
DATABASE_MAX_CONNECTIONS=10

ACCESS_TOKEN_SECRET=development-access-secret
REFRESH_TOKEN_SECRET=development-refresh-secret
PENDING_TOKEN_SECRET=development-pending-secret
DATA_ENCRYPTION_SECRET=development-data-secret
JWT_ISSUER=nrg-commerce-api
JWT_AUDIENCE=nrg-commerce-admin

ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
PENDING_TOKEN_TTL_SECONDS=300
SESSION_TTL_SECONDS=604800
SESSION_ABSOLUTE_TTL_SECONDS=2592000

TOTP_ISSUER=NRG Commerce
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=NRG Commerce
WEBAUTHN_ORIGIN=http://localhost:5173
# Production WEBAUTHN_ORIGIN must match the admin origin, and WEBAUTHN_RP_ID must match its host or parent domain.

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

R2_ACCOUNT_ID=development-account-id
R2_BUCKET_NAME=development-bucket
R2_UPLOAD_BUCKET_NAME=development-upload-bucket
R2_ACCESS_KEY_ID=development-access-key-id
R2_SECRET_ACCESS_KEY=development-secret-access-key
R2_PUBLIC_BASE_URL=https://example.com/assets
R2_ASSET_KEY_PREFIX=products/skus
R2_UPLOAD_URL_TTL_SECONDS=900
STOREFRONT_CACHE_TTL_SECONDS=60
STOREFRONT_CACHE_MAX_ENTRIES=500

# Production requires an OTLP/HTTP collector endpoint. Keep authentication headers in secret storage.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=authorization=replace-with-collector-token
OTEL_SERVICE_NAME=nrg-commerce-api
OTEL_METRIC_EXPORT_INTERVAL_MS=60000
