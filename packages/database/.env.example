# Direct database connection used by Prisma migrations.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/nrg_commerce

# Separate disposable database used only for migration drift checks and migrate dev.
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nrg_commerce_shadow
# Maintenance database used by db:shadow:create to create the disposable database.
SHADOW_DATABASE_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Application database connection used by the Prisma client.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nrg_commerce

# Production URLs must include sslmode=verify-full for certificate and hostname verification.
