{
	"name": "@packages/components",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --ignore-path ../../.prettierignore --check . && eslint .",
		"format": "prettier --ignore-path ../../.prettierignore --write ."
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"@sveltejs/kit": "catalog:svelte",
		"svelte": "catalog:svelte"
	},
	"dependencies": {
		"@lucide/svelte": "catalog:svelte"
	},
	"devDependencies": {
		"@eslint/js": "catalog:lint",
		"@packages/eslint-config": "workspace:*",
		"@packages/prettier-config": "workspace:*",
		"@packages/styles": "workspace:*",
		"@packages/tsconfig": "workspace:*",
		"@sveltejs/adapter-auto": "catalog:svelte",
		"@sveltejs/kit": "catalog:svelte",
		"@sveltejs/package": "catalog:svelte",
		"@sveltejs/vite-plugin-svelte": "catalog:svelte",
		"@tailwindcss/vite": "catalog:svelte",
		"@types/node": "catalog:",
		"eslint": "catalog:lint",
		"eslint-config-prettier": "catalog:lint",
		"eslint-plugin-svelte": "catalog:lint",
		"globals": "catalog:lint",
		"prettier": "catalog:lint",
		"prettier-plugin-svelte": "catalog:lint",
		"prettier-plugin-tailwindcss": "catalog:lint",
		"publint": "catalog:lint",
		"simple-icons": "catalog:svelte",
		"svelte": "catalog:svelte",
		"svelte-check": "catalog:svelte",
		"tailwindcss": "catalog:svelte",
		"typescript": "catalog:",
		"typescript-eslint": "catalog:lint",
		"vite": "catalog:svelte"
	}
}
